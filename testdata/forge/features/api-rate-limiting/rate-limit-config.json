{
  "endpoint": "/api/v1/*",
  "rules": [
    {
      "name": "authenticated",
      "match": { "authenticated": true },
      "limit": 100,
      "window_seconds": 60,
      "burst": 10
    },
    {
      "name": "unauthenticated",
      "match": { "authenticated": false },
      "limit": 20,
      "window_seconds": 60,
      "burst": 5
    },
    {
      "name": "write_operations",
      "match": { "methods": ["POST", "PUT", "PATCH", "DELETE"] },
      "limit": 30,
      "window_seconds": 60,
      "burst": 5
    }
  ],
  "storage": {
    "type": "redis",
    "key_prefix": "rate_limit:",
    "ttl_buffer_seconds": 5
  },
  "response": {
    "status": 429,
    "headers": {
      "Retry-After": "{{retry_after}}"
    }
  }
}
